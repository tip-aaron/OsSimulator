# Git
.git
.gitignore
.gitmodules

# Premake & Visual Studio Generated Files (Keep these on Windows)
.vs/
*.sln
*.vcxproj
*.vcxproj.*
Makefile
*.make

# C++ Build Artifacts (Docker will generate its own Linux versions)
bin/
bin-int/

# Python Virtual Environments & Cache (Docker uses /opt/venv)
visualizer/venv/
visualizer/env/
__pycache__/
*.pyc

# Simulation Output Data (Don't copy old host data into the container)
data/*.csv
data/*.png

# OS Garbage
.DS_Store
Thumbs.db
